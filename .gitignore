# ----------------------
# Environment variables
# ----------------------
.env
.env.*
!.env.example   # allow example file

# ----------------------
# Python
# ----------------------
__pycache__/
*.py[cod]
*$py.class

# ----------------------
# Virtual environments
# ----------------------
venv/
env/
.venv/

# ----------------------
# Logs
# ----------------------
*.log
logs/

# ----------------------
# Model files (IMPORTANT for ML projects)
# ----------------------
*.h5
*.pt
*.pth
*.ckpt
*.joblib
*.pkl

# ----------------------
# Data files (optional but recommended)
# ----------------------
data/
datasets/

# ----------------------
# Node (if applicable)
# ----------------------
node_modules/

# ----------------------
# Build / distribution
# ----------------------
dist/
build/
*.egg-info/

# ----------------------
# OS files
# ----------------------
.DS_Store
Thumbs.db

# ----------------------
# IDE
# ----------------------
.vscode/
.idea/

# ----------------------
# Jupyter (if used)
# ----------------------
.ipynb_checkpoints/

# ----------------------
# Temporary files
# ----------------------
*.tmp
*.swp