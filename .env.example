# API Keys (DO NOT PUT REAL VALUES)
GROQ_API_KEY=your_groq_api_key_here

# Model Config
GROQ__MODEL_NAME=llama-3.3-70b-versatile

# Weights
RULE_BASED_WEIGHT=0.30
ML_CLASSIFIER_WEIGHT=0.35
LLM_VALIDATOR_WEIGHT=0.35

# Thresholds
BLOCK_THRESHOLD=0.65
SANITIZE_THRESHOLD=0.40

# Classifier
CLASSIFIER_BASE_MODEL=distilbert-base-uncased
CLASSIFIER_MODEL_PATH=models/classifier/fine_tuned

# API Config
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_SECRET_KEY=your_secret_key_here

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/audit.log
LOG_ROTATION=10 MB
LOG_RETENTION=30 days
